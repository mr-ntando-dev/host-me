<%- include('partials/header') %>

<div class="dashboard-header">
  <div>
    <h1>My Apps</h1>
    <p class="text-muted" style="font-size:0.875rem; margin-top:2px;">Welcome back, <strong><%= user.username %></strong></p>
  </div>
  <a href="/apps/create" class="btn btn-primary">＋ Deploy New App</a>
</div>

<!-- Stats -->
<div class="stats-bar">
  <div class="stat">
    <div class="stat-icon">📦</div>
    <span class="stat-value"><%= apps.length %></span>
    <span class="stat-label">/ <%= user.max_apps %> Apps</span>
  </div>
  <div class="stat">
    <div class="stat-icon">🟢</div>
    <span class="stat-value"><%= apps.filter(a => a.status === 'running').length %></span>
    <span class="stat-label">Running</span>
  </div>
  <div class="stat">
    <div class="stat-icon">⏹</div>
    <span class="stat-value"><%= apps.filter(a => a.status === 'stopped').length %></span>
    <span class="stat-label">Stopped</span>
  </div>
  <div class="stat">
    <div class="stat-icon">💾</div>
    <span class="stat-value"><%= user.max_ram_mb %>MB</span>
    <span class="stat-label">RAM Budget</span>
  </div>
</div>

<!-- Git Token -->
<div class="settings-card">
  <h3>🔑 Git Token</h3>
  <p class="text-muted" style="font-size:0.85rem; margin-top:2px;">GitHub / GitLab personal access token for private repo deployments.</p>
  <div class="inline-form">
    <input type="password" id="git-token-input" placeholder="ghp_xxxx or glpat-xxxx"
           value="<%= user.git_token ? '••••••••' : '' %>" style="max-width:360px;">
    <button class="btn btn-secondary" onclick="saveGitToken()">Save Token</button>
  </div>
</div>

<!-- AI Quick Deploy -->
<div class="settings-card ai-section">
  <div class="ai-section-header">
    <h3>🤖 AI Quick Deploy</h3>
    <span class="ai-badge">AI</span>
  </div>
  <p class="text-muted" style="font-size:0.85rem; margin-bottom:0.9rem;">Paste a GitHub repo URL — AI auto-detects entry file, RAM needs, env vars and app name.</p>
  <div class="inline-form">
    <input type="url" id="ai-repo-url" placeholder="https://github.com/user/my-node-app">
    <button class="btn btn-ai" onclick="aiQuickDeploy()" id="ai-detect-btn">
      <span id="ai-detect-icon">✨</span> Auto-Detect Config
    </button>
  </div>
  <div id="ai-detection-result" style="display:none" class="ai-result-card">
    <div class="ai-result-header">
      <strong>🤖 AI Detected Configuration</strong>
      <button class="btn btn-sm btn-primary" onclick="applyAiConfig()" style="margin-left:auto">Use This Config →</button>
    </div>
    <div id="ai-config-preview" class="ai-config-grid" style="margin-top:0.75rem"></div>
    <p id="ai-notes" class="text-muted" style="margin-top:0.75rem; font-size:0.82rem;"></p>
  </div>
</div>

<% if (apps.length === 0) { %>
<div class="empty-state">
  <div class="empty-state-icon">🚀</div>
  <h2>No apps deployed yet</h2>
  <p>Deploy your first Node.js app from a Git repository in seconds.</p>
  <a href="/apps/create" class="btn btn-primary">Deploy Your First App →</a>
</div>
<% } else { %>
<div class="apps-grid">
  <% apps.forEach(app => { %>
  <div class="app-card">
    <div class="app-card-header">
      <h3><a href="/apps/<%= app.id %>"><%= app.name %></a></h3>
      <span class="status-badge status-<%= app.status %>"><%= app.status %></span>
    </div>
    <div class="app-card-body">
      <p><%= app.repo_url || 'No repo configured' %></p>
      <div class="app-card-meta">
        <span>:<%=app.port%></span>
        <span><%=app.ram_limit_mb%>MB</span>
        <span><%=app.branch || 'main'%></span>
      </div>
    </div>
    <div class="app-card-actions">
      <% if (app.status === 'running') { %>
      <button class="btn btn-sm btn-warning" onclick="appAction(<%= app.id %>, 'restart')">🔄 Restart</button>
      <button class="btn btn-sm btn-danger" onclick="appAction(<%= app.id %>, 'stop')">⏹ Stop</button>
      <% } else { %>
      <button class="btn btn-sm btn-success" onclick="appAction(<%= app.id %>, 'deploy')">🚀 Deploy</button>
      <% } %>
      <a href="/apps/<%= app.id %>" class="btn btn-sm btn-secondary" style="margin-left:auto">Manage →</a>
    </div>
  </div>
  <% }); %>
</div>
<% } %>

<script>
let detectedConfig = null;

async function aiQuickDeploy() {
  const repoUrl = document.getElementById('ai-repo-url').value.trim();
  if (!repoUrl) { showToast('Enter a GitHub repo URL first', 'error'); return; }
  const btn = document.getElementById('ai-detect-btn');
  const icon = document.getElementById('ai-detect-icon');
  btn.disabled = true; icon.textContent = '⏳';
  try {
    const r = await fetch('/ai/detect-config', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ repo_url: repoUrl }) });
    const data = await r.json();
    if (!data.success) throw new Error(data.error);
    detectedConfig = data.config;
    const preview = document.getElementById('ai-config-preview');
    preview.innerHTML = [
      `<div class="ai-config-item"><label>Name</label><value>${data.config.name}</value></div>`,
      `<div class="ai-config-item"><label>Entry File</label><value>${data.config.entry_file}</value></div>`,
      `<div class="ai-config-item"><label>Branch</label><value>${data.config.branch}</value></div>`,
      `<div class="ai-config-item"><label>RAM Limit</label><value>${data.config.ram_limit}MB</value></div>`,
    ].join('');
    document.getElementById('ai-notes').textContent = data.config.notes || '';
    document.getElementById('ai-detection-result').style.display = 'block';
    showToast('AI config detected!', 'success');
  } catch(e) { showToast('AI detection failed: ' + e.message, 'error'); }
  finally { btn.disabled = false; icon.textContent = '✨'; }
}

function applyAiConfig() {
  if (!detectedConfig) return;
  sessionStorage.setItem('aiConfig', JSON.stringify(detectedConfig));
  sessionStorage.setItem('aiRepoUrl', document.getElementById('ai-repo-url').value.trim());
  window.location.href = '/apps/create';
}

async function saveGitToken() {
  const token = document.getElementById('git-token-input').value.trim();
  if (!token || token === '••••••••') { showToast('Enter a valid token', 'error'); return; }
  try {
    const r = await fetch('/apps/git-token', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ token }) });
    const d = await r.json();
    if (d.success) showToast('Git token saved', 'success');
    else showToast(d.error || 'Failed', 'error');
  } catch(e) { showToast('Error saving token', 'error'); }
}
</script>

<%- include('partials/footer') %>
