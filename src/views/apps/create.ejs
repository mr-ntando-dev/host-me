<%- include('../partials/header') %>

<div class="form-container">
  <div class="page-header">
    <h1>Deploy New App</h1>
    <p class="page-desc">Connect a Git repository and Speceify will clone, install dependencies, and start your app with PM2.</p>
  </div>

  <% if (error) { %>
  <div class="alert alert-error">⚠️ <%= error %></div>
  <% } %>

  <form method="POST" action="/apps/create" id="create-form">

    <div class="form-section">
      <div class="form-section-title">Repository</div>
      <div class="form-group">
        <label>App Name</label>
        <input type="text" name="name" id="app-name" placeholder="my-cool-app" required minlength="2" maxlength="30">
        <small>Lowercase letters, numbers and hyphens only</small>
      </div>
      <div class="form-group">
        <label>Git Repository URL</label>
        <input type="url" name="repo_url" id="repo-url" placeholder="https://github.com/user/my-app.git" required>
      </div>
      <div class="form-group">
        <label>Branch</label>
        <input type="text" name="branch" id="branch" value="main" placeholder="main">
      </div>
    </div>

    <div class="form-section">
      <div class="form-section-title">Runtime Config</div>
      <div class="form-group">
        <label>Entry File</label>
        <input type="text" name="entry_file" id="entry-file" value="index.js" placeholder="index.js or src/index.js">
        <small>The main file Node.js should run (check scripts.start in package.json)</small>
      </div>
      <div class="form-group">
        <label>RAM Limit (MB)</label>
        <input type="number" name="ram_limit" id="ram-limit" value="256" min="64" max="2048">
        <small>App restarts if it exceeds this limit. Simple APIs: 128MB, Express: 256MB, heavy: 512MB+</small>
      </div>
    </div>

    <div style="display:flex; gap:0.75rem; align-items:center; flex-wrap:wrap;">
      <button type="submit" class="btn btn-primary">🚀 Deploy App</button>
      <a href="/dashboard" class="btn btn-secondary">Cancel</a>
    </div>
  </form>
</div>

<script>
// Pre-fill from AI detection if available
const aiConfig = sessionStorage.getItem('aiConfig');
const aiRepoUrl = sessionStorage.getItem('aiRepoUrl');
if (aiConfig) {
  const c = JSON.parse(aiConfig);
  if (document.getElementById('app-name')) document.getElementById('app-name').value = c.name || '';
  if (document.getElementById('entry-file')) document.getElementById('entry-file').value = c.entry_file || 'index.js';
  if (document.getElementById('branch')) document.getElementById('branch').value = c.branch || 'main';
  if (document.getElementById('ram-limit')) document.getElementById('ram-limit').value = c.ram_limit || 256;
  if (aiRepoUrl && document.getElementById('repo-url')) document.getElementById('repo-url').value = aiRepoUrl;
  sessionStorage.removeItem('aiConfig');
  sessionStorage.removeItem('aiRepoUrl');
  showToast('AI config pre-filled!', 'success');
}
</script>

<%- include('../partials/footer') %>
