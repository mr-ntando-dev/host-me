<%- include('../partials/header') %>

<div class="app-detail-header">
  <div>
    <h1><%= app.name %> <span class="status-badge status-<%= app.status %>"><%= app.status %></span></h1>
    <p class="text-muted" style="font-size:0.85rem; margin-top:4px;"><%= app.repo_url || 'No repo configured' %></p>
  </div>
  <div class="app-actions">
    <% if (app.status !== 'running') { %>
    <button class="btn btn-success" onclick="appAction(<%= app.id %>, 'deploy')">🚀 Deploy</button>
    <% } %>
    <% if (app.status === 'running') { %>
    <button class="btn btn-warning" onclick="appAction(<%= app.id %>, 'restart')">🔄 Restart</button>
    <button class="btn btn-danger" onclick="appAction(<%= app.id %>, 'stop')">⏹ Stop</button>
    <% } %>
    <button class="btn btn-danger-outline" onclick="deleteApp(<%= app.id %>)">🗑 Delete</button>
  </div>
</div>

<!-- Info Grid -->
<div class="info-grid">
  <div class="info-card">
    <h3>📋 Details</h3>
    <table class="info-table">
      <tr><td>Port</td><td><code><%= app.port %></code></td></tr>
      <tr><td>Entry File</td><td><code><%= app.entry_file %></code></td></tr>
      <tr><td>Branch</td><td><code><%= app.branch %></code></td></tr>
      <tr><td>RAM Limit</td><td><%= app.ram_limit_mb %> MB</td></tr>
      <tr><td>Auto Restart</td><td><%= app.auto_restart ? '✅ Yes' : '❌ No' %></td></tr>
      <tr><td>Repo</td><td class="text-truncate"><a href="<%= app.repo_url %>" target="_blank"><%= app.repo_url %></a></td></tr>
      <% if (app.domain) { %><tr><td>Domain</td><td><a href="http://<%= app.domain %>" target="_blank"><%= app.domain %></a></td></tr><% } %>
    </table>
  </div>

  <% if (info) { %>
  <div class="info-card">
    <h3>📊 Runtime</h3>
    <table class="info-table">
      <tr><td>Status</td><td><span class="status-badge status-<%= info.status %>"><%= info.status %></span></td></tr>
      <tr><td>Memory</td><td>
        <%= info.memory %> / <%= app.ram_limit_mb %>MB
        <div class="ram-bar"><div class="ram-bar-fill" style="width:<%= Math.min(100, Math.round(info.memory/app.ram_limit_mb*100)) %>%"></div></div>
      </td></tr>
      <tr><td>CPU</td><td><%= info.cpu %>%</td></tr>
      <tr><td>Restarts</td><td><%= info.restarts %></td></tr>
      <tr><td>Uptime</td><td><%= Math.round(info.uptime / 1000 / 60) %> min</td></tr>
    </table>
  </div>
  <% } %>
</div>

<!-- AI Assistant -->
<div class="section-card ai-section">
  <div class="ai-section-header">
    <h3>🤖 AI Assistant</h3>
    <span class="ai-badge">AI</span>
  </div>
  <p class="text-muted" style="font-size:0.85rem; margin-bottom:1rem;">Ask anything about this app — debug errors, optimize config, set up env vars.</p>
  <div class="ai-quick-actions">
    <button class="btn btn-sm btn-ai-outline" onclick="aiQuickAction('Analyze the logs and tell me if there are any errors or problems')">🔍 Diagnose logs</button>
    <button class="btn btn-sm btn-ai-outline" onclick="aiQuickAction('What environment variables does this app need?')">⚙️ Suggest env vars</button>
    <button class="btn btn-sm btn-ai-outline" onclick="aiQuickAction('What RAM limit would you recommend for this app and why?')">💾 Optimize RAM</button>
    <button class="btn btn-sm btn-ai-outline" onclick="aiQuickAction('Why might this app be crashing or failing to start?')">🚨 Debug crashes</button>
  </div>
  <div id="ai-chat-messages" class="ai-chat-messages"></div>
  <div class="ai-chat-input-row">
    <input type="text" id="ai-chat-input" placeholder="Ask about this app..." onkeydown="if(event.key==='Enter') sendAiMessage()">
    <button class="btn btn-ai" onclick="sendAiMessage()" id="ai-send-btn">Send</button>
  </div>
</div>

<!-- Env Variables -->
<div class="section-card">
  <div style="display:flex; align-items:center; gap:10px; margin-bottom:0.25rem;">
    <h3 style="margin:0;">⚙️ Environment Variables</h3>
    <button class="btn btn-sm btn-ai-outline" onclick="aiSuggestEnv(<%= app.id %>)" id="ai-env-btn">✨ AI Suggest</button>
  </div>
  <p class="text-muted" style="font-size:0.85rem; margin-bottom:1.25rem;">PORT is auto-injected. Redeploy after saving to apply changes.</p>
  <div id="env-rows" class="env-rows"></div>
  <button class="btn btn-sm btn-secondary" onclick="addEnvRow()" style="margin-bottom:1rem;">+ Add Variable</button>
  <br>
  <button class="btn btn-primary" onclick="saveEnvVars(<%= app.id %>)">💾 Save Variables</button>
</div>

<!-- Logs -->
<div class="section-card">
  <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:0.25rem;">
    <h3 style="margin:0;">📜 Live Logs</h3>
    <button class="btn btn-sm btn-secondary" onclick="refreshLogs()">↻ Refresh</button>
  </div>
  <p class="text-muted" style="font-size:0.85rem; margin-bottom:0.75rem;">Last 100 lines from PM2</p>
  <div class="log-output" id="log-output">Click refresh to load logs...</div>
</div>

<!-- Deploy History -->
<% if (logs && logs.length > 0) { %>
<div class="section-card">
  <h3 style="margin-bottom:1rem;">📅 Deploy History</h3>
  <table class="deploy-table">
    <thead>
      <tr><th>Time</th><th>Action</th><th>Status</th><th>Output</th></tr>
    </thead>
    <tbody>
      <% logs.forEach(log => { %>
      <tr>
        <td class="text-muted" style="font-size:0.78rem; white-space:nowrap;"><%= log.created_at %></td>
        <td><code><%= log.action %></code></td>
        <td><span class="status-badge status-<%= log.status %>"><%= log.status %></span></td>
        <td class="text-muted" style="font-size:0.8rem; max-width:300px; overflow:hidden; text-overflow:ellipsis;"><%= log.output %></td>
      </tr>
      <% }); %>
    </tbody>
  </table>
</div>
<% } %>

<script>
const APP_ID = <%= app.id %>;
let aiChatHistory = [];

// Env vars
const existingEnv = <%- JSON.stringify(app.env_vars || '{}') %>;
let envData = {};
try { envData = JSON.parse(existingEnv); } catch(e) { envData = {}; }

function renderEnvRows() {
  const container = document.getElementById('env-rows');
  container.innerHTML = '';
  Object.entries(envData).forEach(([k, v]) => {
    const row = document.createElement('div');
    row.className = 'env-row';
    row.innerHTML = `
      <input type="text" value="${escHtml(k)}" placeholder="KEY" class="env-key" oninput="rebuildEnvData()">
      <input type="text" value="${escHtml(v)}" placeholder="value" class="env-val" oninput="rebuildEnvData()">
      <button class="btn btn-sm btn-danger-outline" onclick="this.closest('.env-row').remove(); rebuildEnvData()">✕</button>`;
    container.appendChild(row);
  });
}

function escHtml(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }

function addEnvRow() {
  envData[''] = '';
  renderEnvRows();
  const rows = document.querySelectorAll('.env-row');
  if (rows.length) rows[rows.length-1].querySelector('.env-key').focus();
}

function rebuildEnvData() {
  const nd = {};
  document.querySelectorAll('.env-row').forEach(row => {
    const k = row.querySelector('.env-key').value.trim();
    const v = row.querySelector('.env-val').value;
    if (k) nd[k] = v;
  });
  envData = nd;
}

async function saveEnvVars(id) {
  rebuildEnvData();
  try {
    const r = await fetch(`/apps/${id}/env`, { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ env_vars: JSON.stringify(envData) }) });
    const d = await r.json();
    if (d.success) showToast('Env vars saved! Redeploy to apply.', 'success');
    else showToast(d.error || 'Failed', 'error');
  } catch(e) { showToast('Error saving', 'error'); }
}

async function aiSuggestEnv(id) {
  const btn = document.getElementById('ai-env-btn');
  btn.disabled = true; btn.textContent = '⏳ Loading...';
  try {
    const r = await fetch('/ai/suggest-env', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ app_id: id }) });
    const d = await r.json();
    if (!d.success) throw new Error(d.error);
    const suggested = d.env_vars || {};
    Object.entries(suggested).forEach(([k, v]) => { if (!envData[k]) envData[k] = v; });
    renderEnvRows();
    showToast(`AI suggested ${Object.keys(suggested).length} env vars (source: ${d.source})`, 'success');
  } catch(e) { showToast('AI suggest failed: ' + e.message, 'error'); }
  finally { btn.disabled = false; btn.textContent = '✨ AI Suggest'; }
}

function refreshLogs() {
  const out = document.getElementById('log-output');
  out.textContent = 'Loading...';
  fetch(`/apps/${APP_ID}/logs`).then(r=>r.json()).then(d=>{ out.textContent = d.logs || 'No logs'; out.scrollTop = out.scrollHeight; }).catch(()=>{ out.textContent = 'Failed to load logs'; });
}

// AI Chat
function appendAiMsg(role, content) {
  const box = document.getElementById('ai-chat-messages');
  const div = document.createElement('div');
  div.className = `ai-msg ai-msg-${role}`;
  if (role === 'assistant') div.innerHTML = renderMarkdown(content);
  else div.textContent = content;
  box.appendChild(div);
  box.scrollTop = box.scrollHeight;
  return div;
}

function renderMarkdown(md) {
  return md
    .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
    .replace(/```[\w]*\n?([\s\S]*?)```/g, '<pre><code>$1</code></pre>')
    .replace(/`([^`]+)`/g, '<code>$1</code>')
    .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
    .replace(/^#{1,3}\s+(.+)$/gm, '<h3>$1</h3>')
    .replace(/^\s*[-*]\s+(.+)$/gm, '<li>$1</li>')
    .replace(/\n{2,}/g, '</p><p>')
    .replace(/\n/g, '<br>');
}

async function sendAiMessage() {
  const input = document.getElementById('ai-chat-input');
  const msg = input.value.trim();
  if (!msg) return;
  input.value = '';
  appendAiMsg('user', msg);
  aiChatHistory.push({ role: 'user', content: msg });
  const loading = appendAiMsg('assistant', '');
  loading.className = 'ai-msg ai-msg-assistant ai-msg-loading';
  loading.innerHTML = '<span></span><span></span><span></span>';
  const btn = document.getElementById('ai-send-btn');
  btn.disabled = true;
  const context = `App: <%= app.name %>, Repo: <%= app.repo_url %>, Entry: <%= app.entry_file %>, Port: <%= app.port %>, RAM: <%= app.ram_limit_mb %>MB, Status: <%= app.status %>`;
  try {
    const r = await fetch('/ai/chat', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ message: msg, context, history: aiChatHistory.slice(-6) }) });
    const d = await r.json();
    if (!d.success) throw new Error(d.error);
    loading.className = 'ai-msg ai-msg-assistant';
    loading.innerHTML = renderMarkdown(d.reply);
    aiChatHistory.push({ role: 'assistant', content: d.reply });
  } catch(e) {
    loading.className = 'ai-msg ai-msg-assistant';
    loading.textContent = 'Error: ' + e.message;
  }
  btn.disabled = false;
  document.getElementById('ai-chat-messages').scrollTop = 99999;
}

function aiQuickAction(msg) {
  document.getElementById('ai-chat-input').value = msg;
  sendAiMessage();
}

renderEnvRows();
</script>

<%- include('../partials/footer') %>
