<%- include('../partials/header') %>

<div class="admin-panel">
  <h1>Manage User: <%= targetUser.username %></h1>

  <div class="section-card">
    <h3>Resource Limits</h3>
    <form id="limits-form" class="inline-form-grid">
      <div class="form-group">
        <label>Max Apps</label>
        <input type="number" id="max-apps" value="<%= targetUser.max_apps %>" min="1" max="50">
      </div>
      <div class="form-group">
        <label>Max RAM (MB)</label>
        <input type="number" id="max-ram" value="<%= targetUser.max_ram_mb %>" min="128" max="3072">
      </div>
      <div class="form-group">
        <label>Max Storage (MB)</label>
        <input type="number" id="max-storage" value="<%= targetUser.max_storage_mb %>" min="256" max="10240">
      </div>
      <button type="button" class="btn btn-primary" onclick="updateLimits(<%= targetUser.id %>)">Save Limits</button>
    </form>
  </div>

  <div class="section-card">
    <h3>User's Apps (<%= apps.length %>)</h3>
    <% if (apps.length === 0) { %>
    <p class="text-muted">No apps yet.</p>
    <% } else { %>
    <table class="admin-table">
      <thead>
        <tr><th>Name</th><th>Status</th><th>Port</th><th>RAM</th></tr>
      </thead>
      <tbody>
        <% apps.forEach(app => { %>
        <tr>
          <td><%= app.name %></td>
          <td><span class="status-badge status-<%= app.status %>"><%= app.status %></span></td>
          <td><%= app.port %></td>
          <td><%= app.ram_limit_mb %>MB</td>
        </tr>
        <% }); %>
      </tbody>
    </table>
    <% } %>
  </div>

  <a href="/admin" class="btn btn-secondary">← Back to Admin</a>
</div>

<%- include('../partials/footer') %>
