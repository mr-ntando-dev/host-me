<%- include('../partials/header') %>

<div class="form-container">
  <div class="page-header">
    <h1>Edit User: <%= editUser.username %></h1>
    <p>Adjust resource limits and role for this user.</p>
  </div>

  <% if (typeof error !== 'undefined' && error) { %>
  <div class="alert alert-error">⚠️ <%= error %></div>
  <% } %>
  <% if (typeof success !== 'undefined' && success) { %>
  <div class="alert alert-success">✅ <%= success %></div>
  <% } %>

  <div class="form-section">
    <div class="form-section-title">User Info</div>
    <table class="info-table" style="margin-bottom:0">
      <tr><td>Username</td><td><strong><%= editUser.username %></strong></td></tr>
      <tr><td>Email</td><td><%= editUser.email %></td></tr>
      <tr><td>Role</td><td><span class="role-badge role-<%= editUser.role %>"><%= editUser.role %></span></td></tr>
      <tr><td>Joined</td><td><%= editUser.created_at ? editUser.created_at.slice(0,10) : '-' %></td></tr>
    </table>
  </div>

  <form method="POST" action="/admin/user/<%= editUser.id %>">
    <div class="form-section">
      <div class="form-section-title">Resource Limits</div>
      <div class="form-group">
        <label>Max Apps</label>
        <input type="number" name="max_apps" value="<%= editUser.max_apps %>" min="0" max="100" required>
      </div>
      <div class="form-group">
        <label>Max RAM per App (MB)</label>
        <input type="number" name="max_ram_mb" value="<%= editUser.max_ram_mb %>" min="128" max="8192" required>
      </div>
      <div class="form-group">
        <label>Max Storage (MB)</label>
        <input type="number" name="max_storage_mb" value="<%= editUser.max_storage_mb %>" min="256" max="51200" required>
      </div>
      <div class="form-group">
        <label>Role</label>
        <select name="role">
          <option value="user" <%= editUser.role === 'user' ? 'selected' : '' %>>User</option>
          <option value="admin" <%= editUser.role === 'admin' ? 'selected' : '' %>>Admin</option>
        </select>
      </div>
    </div>
    <div style="display:flex; gap:0.75rem; flex-wrap:wrap;">
      <button type="submit" class="btn btn-primary">Save Changes</button>
      <a href="/admin" class="btn btn-secondary">← Back</a>
    </div>
  </form>
</div>

<%- include('../partials/footer') %>
