# Nginx configuration for speceify.eu
# Place this in /etc/nginx/sites-available/speceify

server {
    listen 80;
    server_name speceify.eu www.speceify.eu;

    # Redirect to HTTPS
    return 301 https://$server_name$request_uri;
}

server {
    listen 443 ssl http2;
    server_name speceify.eu www.speceify.eu;

    # SSL (use certbot to generate)
    ssl_certificate /etc/letsencrypt/live/speceify.eu/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/speceify.eu/privkey.pem;

    # Speceify Panel
    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_cache_bypass $http_upgrade;
    }
}

